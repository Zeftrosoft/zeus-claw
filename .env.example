TELEGRAM_BOT_TOKEN=

# --- LLM Provider ---
# Choose which LLM backend to use: claude (default), vllm, or ollama
# LLM_PROVIDER=claude

# --- vLLM / Ollama Configuration (only used when LLM_PROVIDER is not claude) ---
# Base URL for the OpenAI-compatible API endpoint
# Ollama default: http://localhost:11434/v1
# vLLM default:   http://localhost:8000/v1
# LLM_BASE_URL=http://localhost:11434/v1

# Model name (required for vllm/ollama)
# Examples: qwen3-coder:30b, llama3.2, meta-llama/Llama-3.1-70B-Instruct
# LLM_MODEL=qwen3-coder:30b

# API key (optional, only needed if your vLLM instance requires auth)
# LLM_API_KEY=
